---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Terms of Use — Zebra"
	description="Terms of use for Zebra, a symptom tracker for POTS, EDS, and Fibromyalgia."
>
	<div class="legal-shell">
		<a class="legal-back" href="/">← Back to Zebra</a>
		<div class="legal-card">
			<p class="eyebrow">Terms</p>
			<h1>Terms of Use</h1>
			<p class="legal-updated">Last updated: May 14, 2026</p>

			<p>
				By using the Zebra website, you agree to these terms. If you do not agree, please do not
				use the site.
			</p>

			<h2>Website purpose</h2>
			<p>
				This site is provided to share information about Zebra, collect waitlist interest, and
				communicate with potential users.
			</p>

			<h2>No medical advice</h2>
			<p>
				Zebra does not provide medical advice. Nothing on this website is intended to diagnose,
				treat, cure, or prevent any disease or condition. Always seek advice from a qualified
				medical professional.
			</p>

			<h2>Acceptable use</h2>
			<p>
				You agree not to misuse the website, interfere with its operation, or submit false,
				misleading, or harmful information through forms or contact channels.
			</p>

